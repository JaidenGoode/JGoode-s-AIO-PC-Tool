<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
        xmlns:views="clr-namespace:JGoodeAIO.Views"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="JGoodeAIO.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="JGoode A.I.O PC Tool"
        Width="1200" Height="780"
        MinWidth="920" MinHeight="600"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

  <Grid RowDefinitions="38,1,*">

    <!-- ══ Titlebar ══ -->
    <Grid Grid.Row="0" ColumnDefinitions="220,*,Auto"
          Background="{DynamicResource SidebarBg}">

      <!-- Brand (left — sits over the sidebar column, doubles as drag zone) -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9"
                  VerticalAlignment="Center" Margin="14,0"
                  PointerPressed="OnTitlebarPress">
        <Border Background="{DynamicResource AccentBrush}" CornerRadius="6"
                Width="22" Height="22">
          <TextBlock Text="J" FontSize="11" FontWeight="Black" Foreground="White"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="JGoode A.I.O PC Tool" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Drag zone over content area -->
      <Border Grid.Column="1" Background="{DynamicResource AppBackground}"
              PointerPressed="OnTitlebarPress"/>

      <!-- Window controls -->
      <StackPanel Grid.Column="2" Orientation="Horizontal"
                  Background="{DynamicResource AppBackground}" VerticalAlignment="Stretch">
        <Button Width="46" Height="38" Classes="titlebar-btn"
                Click="OnMinimize">
          <mi:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
        </Button>
        <Button Width="46" Height="38" Classes="titlebar-btn"
                Click="OnMaximize">
          <mi:MaterialIcon Kind="WindowMaximize" Width="13" Height="13"/>
        </Button>
        <Button Width="46" Height="38" Classes="titlebar-btn-close"
                Click="OnClose">
          <mi:MaterialIcon Kind="Close" Width="15" Height="15"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Titlebar bottom separator -->
    <Border Grid.Row="1" Background="{DynamicResource CardBorder}"/>

    <!-- ══ Main layout ══ -->
    <Grid Grid.Row="2" ColumnDefinitions="220,*">

      <!-- ── Sidebar ── -->
      <Border Grid.Column="0" Background="{DynamicResource SidebarBg}"
              BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">

          <!-- Nav items -->
          <StackPanel Grid.Row="0" Margin="0,12,0,0">

            <Button x:Name="BtnDashboard" Classes="nav-item"
                    Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <mi:MaterialIcon Kind="ViewDashboard" Width="17" Height="17"/>
                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="BtnTweaks" Classes="nav-item"
                    Command="{Binding NavigateCommand}" CommandParameter="Tweaks">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <mi:MaterialIcon Kind="TuneVariant" Width="17" Height="17"/>
                <TextBlock Text="Tweaks" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="BtnCleaner" Classes="nav-item"
                    Command="{Binding NavigateCommand}" CommandParameter="Cleaner">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <mi:MaterialIcon Kind="Broom" Width="17" Height="17"/>
                <TextBlock Text="Cleaner" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="BtnSettings" Classes="nav-item"
                    Command="{Binding NavigateCommand}" CommandParameter="Settings">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <mi:MaterialIcon Kind="Cog" Width="17" Height="17"/>
                <TextBlock Text="Settings" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="BtnGitHub" Classes="nav-item"
                    Command="{Binding NavigateCommand}" CommandParameter="GitHub">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <mi:MaterialIcon Kind="Github" Width="17" Height="17"/>
                <TextBlock Text="GitHub" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

          </StackPanel>

          <!-- Version label pinned to bottom -->
          <TextBlock Grid.Row="1" Text="v1.0 · .NET 8 · Avalonia"
                     FontSize="10" Foreground="{DynamicResource TextMuted}"
                     Margin="16,0,16,14" HorizontalAlignment="Left"/>
        </Grid>
      </Border>

      <!-- ── Content area ── -->
      <ContentControl Grid.Column="1" Content="{Binding CurrentPage}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
          </DataTemplate>
          <DataTemplate DataType="{x:Type vm:TweaksViewModel}">
            <views:TweaksView/>
          </DataTemplate>
          <DataTemplate DataType="{x:Type vm:CleanerViewModel}">
            <views:CleanerView/>
          </DataTemplate>
          <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
          </DataTemplate>
          <DataTemplate DataType="{x:Type vm:GithubViewModel}">
            <views:GithubView/>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

    </Grid>
  </Grid>
</Window>
