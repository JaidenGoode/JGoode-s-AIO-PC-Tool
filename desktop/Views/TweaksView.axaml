<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="JGoodeAIO.Views.TweaksView"
             x:DataType="vm:TweaksViewModel"
             Background="{DynamicResource AppBackground}">

  <Grid RowDefinitions="Auto,*">

    <!-- ── Fixed header ── -->
    <StackPanel Grid.Row="0" Margin="28,22,28,10">

      <!-- Title + Apply -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Classes="page-title" Text="System Tweaks"/>
          <TextBlock Classes="page-subtitle"
                     Text="{Binding EnabledCount,
                       StringFormat='Toggle tweaks on or off · {0} selected · Press Apply to run'}"/>
        </StackPanel>

        <Button Grid.Column="1" Classes="primary"
                Command="{Binding ApplyCommand}"
                IsEnabled="{Binding !IsBusy}"
                VerticalAlignment="Center" Padding="20,11">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="Play" Width="16" Height="16" VerticalAlignment="Center"/>
            <TextBlock Text="Apply" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Quick-select row -->
      <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,12,0,0">
        <TextBlock Text="Select:" Foreground="{DynamicResource TextMuted}"
                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <Button Classes="ghost" FontSize="12" Padding="10,5"
                Command="{Binding SelectAllCommand}" Content="All"/>
        <TextBlock Text="·" Foreground="{DynamicResource TextMuted}"
                   FontSize="13" VerticalAlignment="Center" Margin="4,0"/>
        <Button Classes="ghost" FontSize="12" Padding="10,5"
                Command="{Binding SelectNoneCommand}" Content="None"/>
        <TextBlock Text="·" Foreground="{DynamicResource TextMuted}"
                   FontSize="13" VerticalAlignment="Center" Margin="4,0"/>
        <Button Classes="ghost" FontSize="12" Padding="10,5"
                Command="{Binding SelectRecommendedCommand}" Content="Recommended"/>
        <TextBlock Text="(no warnings)" Foreground="{DynamicResource TextMuted}"
                   FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
      </StackPanel>

      <!-- Apply progress (visible while running) -->
      <Border Classes="card" Margin="0,12,0,0" Padding="14,12"
              IsVisible="{Binding IsBusy}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding ProgressLabel}"
                     Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
          <ProgressBar Value="{Binding ProgressDone}" Maximum="{Binding ProgressTotal}"
                       Minimum="0" IsIndeterminate="False" Height="4"/>
        </StackPanel>
      </Border>

      <!-- Status message -->
      <Border Classes="card" Margin="0,6,0,0" Padding="14,9"
              IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
      </Border>

      <!-- Search + filter -->
      <Grid ColumnDefinitions="*,10,160" Margin="0,12,0,0">
        <TextBox Grid.Column="0" Watermark="Search tweaks…" Text="{Binding SearchQuery}"/>
        <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"/>
      </Grid>

    </StackPanel>

    <!-- ── Scrollable tweak list ── -->
    <ScrollViewer Grid.Row="1" Padding="28,4,28,24">
      <ItemsControl ItemsSource="{Binding FilteredTweaks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:TweakItemViewModel}">
            <Border Classes="card" Margin="0,0,0,7" Padding="16,13">
              <Grid ColumnDefinitions="*,Auto">

                <!-- Text content -->
                <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,14,0">

                  <!-- Title + badges -->
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Tweak.Title}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Border Classes="badge" Background="{DynamicResource HoverBg}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding Tweak.Category}"
                                 FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    </Border>
                    <Border Classes="badge-warning" VerticalAlignment="Center"
                            IsVisible="{Binding Tweak.Warning,
                              Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                      <TextBlock Text="⚠ Warning" FontSize="11"
                                 Foreground="{DynamicResource WarningBrush}"/>
                    </Border>
                  </StackPanel>

                  <!-- Description -->
                  <TextBlock Text="{Binding Tweak.Description}"
                             Classes="label" FontSize="12" TextWrapping="Wrap"/>

                  <!-- Warning box -->
                  <Border IsVisible="{Binding Tweak.Warning,
                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          Background="#1c1600" CornerRadius="6" Padding="10,7">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <mi:MaterialIcon Kind="AlertOutline" Width="13" Height="13"
                                       Foreground="{DynamicResource WarningBrush}"
                                       VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Tweak.Warning}" FontSize="12"
                                 Foreground="{DynamicResource WarningBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>

                  <!-- Result -->
                  <Border IsVisible="{Binding StatusMessage,
                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          CornerRadius="6" Padding="10,5"
                          Background="{DynamicResource HoverBg}">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"/>
                  </Border>

                </StackPanel>

                <!-- Toggle -->
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsActive}"
                              OffContent="" OnContent=""
                              VerticalAlignment="Top" Margin="0,2,0,0"/>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>
</UserControl>
