<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="JGoodeAIO.Views.GithubView"
             x:DataType="vm:GithubViewModel"
             Background="{DynamicResource AppBackground}">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="28,24,28,28" Spacing="16">

      <!-- Header -->
      <TextBlock Classes="page-title" Text="GitHub Integration"/>
      <TextBlock Classes="page-subtitle"
                 Text="Push your tweak configuration and settings to a GitHub repository"
                 Margin="0,0,0,4"/>

      <!-- Token -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <StackPanel Spacing="3">
            <TextBlock Classes="section-title" Text="Personal Access Token"/>
            <TextBlock Classes="label" FontSize="12"
                       Text="Create a token at github.com/settings/tokens — enable the repo scope"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,10,Auto">
            <TextBox Grid.Column="0" Watermark="ghp_xxxxxxxxxxxxxxxxxxxx"
                     Text="{Binding Token}" PasswordChar="•"/>
            <Button Grid.Column="2" Classes="primary" Content="Verify Token"
                    Command="{Binding VerifyTokenCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
          </Grid>

          <!-- Verified banner -->
          <Border IsVisible="{Binding IsVerified}"
                  Background="#0d2e12" CornerRadius="8" Padding="12,9">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <mi:MaterialIcon Kind="CheckCircle" Width="15" Height="15"
                               Foreground="{DynamicResource SuccessBrush}"
                               VerticalAlignment="Center"/>
              <TextBlock Text="{Binding StatusMessage}"
                         Foreground="{DynamicResource SuccessBrush}"
                         FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Repo config (locked until verified) -->
      <Border Classes="card" IsEnabled="{Binding IsVerified}">
        <StackPanel Spacing="14">
          <TextBlock Classes="section-title" Text="Repository Configuration"/>
          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="Repository Name"/>
            <TextBox Text="{Binding RepoName}" Watermark="my-pc-settings"/>
          </StackPanel>
          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="Description (optional)"/>
            <TextBox Text="{Binding RepoDescription}" Watermark="My PC optimization settings"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="3">
              <TextBlock Text="Private Repository" FontSize="14"
                         Foreground="{DynamicResource TextPrimary}"/>
              <TextBlock Text="Only you can see this repository" Classes="label" FontSize="12"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsPrivate}"
                          OffContent="" OnContent="" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Push button -->
      <Button Classes="primary" HorizontalAlignment="Stretch"
              Command="{Binding PushSettingsCommand}"
              IsEnabled="{Binding IsVerified}" Padding="0,14">
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <mi:MaterialIcon Kind="CloudUpload" Width="18" Height="18"
                           VerticalAlignment="Center"/>
          <TextBlock Text="Push Settings to GitHub" FontSize="14"
                     FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Busy indicator -->
      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="4"/>

      <!-- Status (when not yet verified) -->
      <Border Classes="card" Padding="14,10"
              IsVisible="{Binding !IsVerified}">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <mi:MaterialIcon Kind="InformationOutline" Width="15" Height="15"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
          <TextBlock Text="{Binding StatusMessage}"
                     Foreground="{DynamicResource TextSecondary}"
                     FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- Info card -->
      <Border Classes="card" Background="{DynamicResource AccentDimBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="What gets pushed?" FontWeight="SemiBold" FontSize="13"
                     Foreground="{DynamicResource AccentBrush}"/>
          <TextBlock Classes="label" FontSize="12" TextWrapping="Wrap"
                     Text="Your settings.json from AppData\Roaming\JGoodeAIO — accent color, dark mode preference, font size, and all enabled tweak selections."/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
