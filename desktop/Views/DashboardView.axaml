<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="JGoodeAIO.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="{DynamicResource AppBackground}">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="28,24,28,28" Spacing="20">

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0">
          <TextBlock Classes="page-title" Text="Dashboard"/>
          <TextBlock Classes="page-subtitle"
                     Text="Live hardware monitoring · updated every 4 seconds"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                    VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="{DynamicResource SuccessBrush}"
                   VerticalAlignment="Center"/>
          <TextBlock Text="Live" FontSize="12" Foreground="{DynamicResource SuccessBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>

      <!-- Stat Cards Row -->
      <Grid ColumnDefinitions="*,10,*,10,*,10,*">

        <!-- CPU -->
        <Border Classes="card" Grid.Column="0">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="label" Text="CPU"/>
                <TextBlock Classes="value" Text="{Binding CpuLabel}" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                      Background="{DynamicResource AccentDimBrush}" VerticalAlignment="Top">
                <mi:MaterialIcon Kind="Chip" Width="17" Height="17"
                                 Foreground="{DynamicResource AccentBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Grid>
            <ProgressBar Value="{Binding CpuPercent}" Minimum="0" Maximum="100"/>
            <TextBlock Text="{Binding CpuModel}" Classes="muted"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>

        <!-- RAM -->
        <Border Classes="card" Grid.Column="2">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="label" Text="RAM"/>
                <TextBlock Classes="value" Text="{Binding RamLabel}" FontSize="18"
                           Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                      Background="{DynamicResource AccentDimBrush}" VerticalAlignment="Top">
                <mi:MaterialIcon Kind="Memory" Width="17" Height="17"
                                 Foreground="{DynamicResource AccentBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Grid>
            <ProgressBar Value="{Binding RamPercent}" Minimum="0" Maximum="100"/>
            <TextBlock Text="Physical Memory" Classes="muted"/>
          </StackPanel>
        </Border>

        <!-- GPU -->
        <Border Classes="card" Grid.Column="4">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="label" Text="GPU"/>
                <TextBlock Classes="value" Text="{Binding GpuLabel}" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                      Background="{DynamicResource AccentDimBrush}" VerticalAlignment="Top">
                <mi:MaterialIcon Kind="Gpu" Width="17" Height="17"
                                 Foreground="{DynamicResource AccentBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Grid>
            <ProgressBar Value="{Binding GpuPercent}" Minimum="0" Maximum="100"/>
            <TextBlock Text="{Binding GpuModel}" Classes="muted"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>

        <!-- Disk -->
        <Border Classes="card" Grid.Column="6">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="label" Text="Disk"/>
                <TextBlock Classes="value" Text="{Binding DiskLabel}" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                      Background="{DynamicResource AccentDimBrush}" VerticalAlignment="Top">
                <mi:MaterialIcon Kind="Harddisk" Width="17" Height="17"
                                 Foreground="{DynamicResource AccentBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Grid>
            <ProgressBar Value="{Binding DiskPercent}" Minimum="0" Maximum="100"/>
            <TextBlock Text="{Binding DiskTotal}" Classes="muted"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Info Row -->
      <Grid ColumnDefinitions="*,16,*">

        <!-- System Info -->
        <Border Classes="card" Grid.Column="0">
          <StackPanel Spacing="14">
            <TextBlock Classes="section-title" Text="System Information"/>
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="110,*">
                <TextBlock Grid.Column="0" Classes="label" Text="OS"/>
                <TextBlock Grid.Column="1" Text="{Binding OsVersion}"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
              </Grid>
              <Border Background="{DynamicResource CardBorder}" Height="1"/>
              <Grid ColumnDefinitions="110,*">
                <TextBlock Grid.Column="0" Classes="label" Text="Processor"/>
                <TextBlock Grid.Column="1" Text="{Binding CpuModel}"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
              </Grid>
              <Border Background="{DynamicResource CardBorder}" Height="1"/>
              <Grid ColumnDefinitions="110,*">
                <TextBlock Grid.Column="0" Classes="label" Text="Graphics"/>
                <TextBlock Grid.Column="1" Text="{Binding GpuModel}"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
              </Grid>
              <Border Background="{DynamicResource CardBorder}" Height="1"/>
              <Grid ColumnDefinitions="110,*">
                <TextBlock Grid.Column="0" Classes="label" Text="Disk Free"/>
                <TextBlock Grid.Column="1" Text="{Binding DiskFree}"
                           Foreground="{DynamicResource SuccessBrush}" FontSize="13"/>
              </Grid>
              <Border Background="{DynamicResource CardBorder}" Height="1"/>
              <Grid ColumnDefinitions="110,*">
                <TextBlock Grid.Column="0" Classes="label" Text="CPU Temp"/>
                <TextBlock Grid.Column="1" Text="{Binding CpuTemp}"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Disk I/O -->
        <Border Classes="card" Grid.Column="2">
          <StackPanel Spacing="14">
            <TextBlock Classes="section-title" Text="Disk I/O"/>
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="label" Text="Read Speed"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ReadMbps, StringFormat='{}{0:F1} MB/s'}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="13"/>
              </Grid>
              <ProgressBar Value="{Binding ReadMbps}" Minimum="0" Maximum="500"/>

              <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                <TextBlock Grid.Column="0" Classes="label" Text="Write Speed"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding WriteMbps, StringFormat='{}{0:F1} MB/s'}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontWeight="SemiBold" FontSize="13"/>
              </Grid>
              <ProgressBar Value="{Binding WriteMbps}" Minimum="0" Maximum="500"
                           Foreground="{DynamicResource TextMuted}"/>
            </StackPanel>

            <Border Background="{DynamicResource CardBorder}" Height="1"/>

            <TextBlock Classes="section-title" Text="Disk Space"/>
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="label" Text="Total"/>
                <TextBlock Grid.Column="1" Text="{Binding DiskTotal}"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="label" Text="Free"/>
                <TextBlock Grid.Column="1" Text="{Binding DiskFree}"
                           Foreground="{DynamicResource SuccessBrush}" FontSize="13"
                           FontWeight="SemiBold"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
