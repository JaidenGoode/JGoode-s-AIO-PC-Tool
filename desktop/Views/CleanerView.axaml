<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="JGoodeAIO.Views.CleanerView"
             x:DataType="vm:CleanerViewModel"
             Background="{DynamicResource AppBackground}">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="28,24,28,28" Spacing="16">

      <!-- Header -->
      <TextBlock Classes="page-title" Text="System Cleaner"/>
      <TextBlock Classes="page-subtitle"
                 Text="Scan for junk files, then clean to reclaim disk space"
                 Margin="0,0,0,4"/>

      <!-- Actions card -->
      <Border Classes="card" Padding="16,14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Classes="section-title" Text="Scan &amp; Clean"/>
            <TextBlock Classes="label" FontSize="12"
                       Text="Finds temp files, prefetch cache, thumbnails, update leftovers and more"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <Button Classes="ghost" Content="Clean All"
                    Command="{Binding CleanAllCommand}"
                    IsEnabled="{Binding HasScanned}"/>
            <Button Classes="primary" Command="{Binding ScanCommand}"
                    IsEnabled="{Binding !IsScanning}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="Magnify" Width="15" Height="15"
                                 VerticalAlignment="Center"/>
                <TextBlock Text="Scan System" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Network utilities -->
      <Border Classes="card" Padding="16,14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Classes="section-title" Text="Network Utilities"/>
            <TextBlock Classes="label" FontSize="12"
                       Text="Flush DNS resolver cache or reset the full network stack"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <Button Classes="ghost" Content="Flush DNS"
                    Command="{Binding FlushDnsCommand}"/>
            <Button Classes="ghost" Content="Reset Network"
                    Command="{Binding ResetNetworkCommand}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Status bar -->
      <Border Classes="card" Padding="14,10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <mi:MaterialIcon Kind="InformationOutline" Width="15" Height="15"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding StatusMessage}"
                     Foreground="{DynamicResource TextSecondary}"
                     VerticalAlignment="Center" FontSize="13"/>
        </StackPanel>
      </Border>

      <!-- Progress bars -->
      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsScanning}" Height="4"/>
      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsCleaning}" Height="4"/>

      <!-- Category cards grid -->
      <ItemsControl ItemsSource="{Binding Categories}" IsVisible="{Binding HasScanned}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:CleanCategory}">
            <Border Classes="card" Margin="0,0,8,8" Padding="14">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="{Binding Name}"
                             Classes="section-title" FontSize="13"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding SizeMb, StringFormat='{}{0} MB'}"
                             Foreground="{DynamicResource AccentBrush}"
                             FontWeight="Bold" FontSize="13"/>
                </Grid>
                <TextBlock Text="{Binding Description}" Classes="label"
                           FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Total summary -->
      <Border Classes="card" IsVisible="{Binding HasScanned}" Padding="16,14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Classes="section-title" Text="Total Junk Found"/>
            <TextBlock Classes="label" FontSize="12"
                       Text="Press Clean All to remove all categories at once"/>
          </StackPanel>
          <TextBlock Grid.Column="1"
                     Text="{Binding TotalSizeMb, StringFormat='{}{0} MB'}"
                     Foreground="{DynamicResource AccentBrush}"
                     FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- Clean results -->
      <ItemsControl ItemsSource="{Binding Results}" IsVisible="{Binding Results.Count}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:CleanResult}">
            <Border Classes="card" Margin="0,0,0,6" Padding="12,10">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <mi:MaterialIcon Kind="CheckCircle" Width="15" Height="15"
                                 Foreground="{DynamicResource SuccessBrush}"
                                 IsVisible="{Binding Success}" VerticalAlignment="Center"/>
                <mi:MaterialIcon Kind="AlertCircle" Width="15" Height="15"
                                 Foreground="{DynamicResource ErrorBrush}"
                                 IsVisible="{Binding !Success}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Category}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" FontSize="13"/>
                <TextBlock Text="{Binding Message}" Classes="label"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
