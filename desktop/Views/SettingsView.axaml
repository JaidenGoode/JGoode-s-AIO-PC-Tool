<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
             x:Class="JGoodeAIO.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource AppBackground}">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="28,24,28,28" Spacing="16">

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0">
          <TextBlock Classes="page-title" Text="Settings"/>
          <TextBlock Classes="page-subtitle" Text="Customize your JGoode AIO experience"/>
        </StackPanel>
        <Button Grid.Column="1" Classes="ghost" Content="Reset to Defaults"
                Command="{Binding ResetDefaultsCommand}" VerticalAlignment="Center"/>
      </Grid>

      <!-- Accent color picker -->
      <Border Classes="card">
        <StackPanel Spacing="16">
          <StackPanel Spacing="3">
            <TextBlock Classes="section-title" Text="Accent Color"/>
            <TextBlock Classes="label" FontSize="12" Text="13 theme colors to choose from"/>
          </StackPanel>
          <ItemsControl ItemsSource="{Binding AccentColors}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:AccentColorItem}">
                <Button Command="{Binding SelectCommand}" ToolTip.Tip="{Binding Name}"
                        Background="{Binding Brush}"
                        Width="38" Height="38" Margin="4" Padding="0"
                        CornerRadius="19" Cursor="Hand" BorderThickness="0">
                  <TextBlock Text="✓" FontSize="15" FontWeight="Bold" Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding IsSelected}"/>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Appearance -->
      <Border Classes="card">
        <StackPanel Spacing="16">
          <TextBlock Classes="section-title" Text="Appearance"/>

          <!-- Dark mode -->
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="3">
              <TextBlock Text="Dark Mode" FontSize="14"
                         Foreground="{DynamicResource TextPrimary}"/>
              <TextBlock Text="Toggle between dark and light themes" Classes="label" FontSize="12"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkMode}"
                          OffContent="" OnContent="" VerticalAlignment="Center"/>
          </Grid>

          <Border Background="{DynamicResource CardBorder}" Height="1"/>

          <!-- Font size -->
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Font Size" FontSize="14"
                         Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding FontSize, StringFormat='{}{0}px'}"
                         Foreground="{DynamicResource AccentBrush}"
                         FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
            </Grid>
            <Slider Minimum="12" Maximum="20" Value="{Binding FontSize}"
                    TickFrequency="1" IsSnapToTickEnabled="True"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="12px" Classes="muted"/>
              <TextBlock Grid.Column="1" Text="20px" Classes="muted"/>
            </Grid>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- About -->
      <Border Classes="card">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="5">
            <TextBlock Text="JGoode A.I.O PC Tool" FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Version 1.0.0 · .NET 8 · Avalonia UI" Classes="label" FontSize="13"/>
            <TextBlock Classes="label" FontSize="12"
                       Text="47 PowerShell tweaks · 13 accent colors · Live hardware monitoring"/>
            <TextBlock Text="Created by JaidenGoode" Classes="muted" Margin="0,4,0,0"/>
          </StackPanel>
          <Border Grid.Column="1" Width="52" Height="52" CornerRadius="14"
                  Background="{DynamicResource AccentBrush}"
                  VerticalAlignment="Center" Margin="20,0,0,0">
            <TextBlock Text="J" FontSize="24" FontWeight="Black" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
